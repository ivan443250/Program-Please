  m_EditorClassIdentifier: Assembly-CSharp::ElementaryCase.FrogManager
  _strings:
  - Val: "\u041F\u0440\u0438\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u044E \u0442\u0435\u0431\u044F
      \u043D\u0430 \u0442\u0432\u043E\u0435\u043C \u043F\u0435\u0440\u0432\u043E\u043C
      \u0440\u0430\u0431\u043E\u0447\u0435\u043C \u043C\u0435\u0441\u0442\u0435,
      \u0441\u0442\u0430\u0436\u0435\u0440"
  - Val: "\u0422\u0432\u043E\u044F \u0446\u0435\u043B\u044C - \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435
      \u043D\u0430\u0448\u0438\u043C \u0430\u0440\u0445\u0438\u0432\u043E\u043C"
  - Val: "\u0422\u0435\u0431\u0435 \u043F\u0440\u0438\u0439\u0434\u0435\u0442\u0441\u044F
      \u0440\u0435\u0448\u0430\u0442\u044C \u0437\u0430\u0434\u0430\u0447\u0438 \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u044B\u0435
      \u0441 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u0430\u043C\u0438 \u0438
      \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0430\u043C\u0438 \u0434\u0430\u043D\u043D\u044B\u0445
      \u0434\u043B\u044F \u043E\u043F\u0442\u0438\u043C\u0438\u0437\u0430\u0446\u0438\u0438
      \u043F\u043E\u0438\u0441\u043A\u0430 \u0438 \u0440\u0435\u0448\u0435\u043D\u0438\u044F
      \u0437\u0430\u0434\u0430\u0447 \u0445\u0440\u0430\u043D\u0435\u043D\u0438\u044F
      \u0434\u0430\u043D\u043D\u044B\u0445"
  - Val: "\u041F\u0440\u0438\u0441\u0442\u0443\u043F\u0430\u0439"
  _ease: 18
  _frogBody: {fileID: 1729368538}
